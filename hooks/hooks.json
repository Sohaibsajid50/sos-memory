{
  "description": "SOS memory health check hook",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/sos-health-check.js\" --hook --repair",
            "timeout": 60,
            "async": true
          }
        ]
      }
    ]
  }
}
